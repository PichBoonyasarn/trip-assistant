# Shared across all three sub-apps
GOOGLE_MAPS_KEY=your_google_maps_api_key_here
COMPANY_ADDRESS=your_company_address_here

# hotel-finder only
LITEAPI_KEY=your_liteapi_key_here

# Launcher port (default 3000)
PORT=3000

# Web/Render mode: set these to the deployed Render URLs for each sub-app
# (In Electron mode, main.js overrides these with localhost ports automatically)
HOTEL_FINDER_URL=https://hotel-finder-xxxx.onrender.com
HOTEL_INFO_URL=https://hotel-info-xxxx.onrender.com
GENBA_INFO_URL=https://genba-info-xxxx.onrender.com
